<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 默认（targetSdk ≥ 28）禁明文流量。v0idChain 种子目前是明文 ws://（长期方向是种子上 wss://）。
  这里仅对种子域名与本地调试主机放行明文，其余域名仍禁止 —— 比全局 usesCleartextTraffic 更克制。
    · mc.void1211.com —— 公网种子
    · 10.0.2.2        —— Android 模拟器访问“宿主机”的回环别名（本地 dev 节点）
    · 127.0.0.1 / localhost —— 真机本地/转发场景
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">mc.void1211.com</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
